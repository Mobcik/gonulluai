DATABASE_URL=sqlite+aiosqlite:///./gonulluai.db
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_BUCKET=gonulluai-photos

# GönüllüAI metin/görsel özellikleri (Google AI Studio anahtarı). Boşsa yerel şablonlar kullanılır.
GEMINI_API_KEY=your-gemini-api-key

# Mini koç (ve ileride genişletilebilir): kendi makinenizde Ollama. Önce Ollama, yoksa Gemini dener.
# Kurulum: https://ollama.com — örn. ollama pull llama3.2
# Kendi "eğitilmiş" / özelleştirilmiş model: Modelfile veya GGUF import, sonra OLLAMA_MODEL=adınız
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2
# İsteğe bağlı / şu an backend tarafında kullanılmıyor
ANTHROPIC_API_KEY=

REDIS_URL=redis://localhost:6379

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

FRONTEND_URL=http://localhost:5175
# İsteğe bağlı: virgülle birden fazla origin (boş bırakılırsa yalnızca FRONTEND_URL)
# CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5175
